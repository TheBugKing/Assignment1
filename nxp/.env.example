# RAG NXP — local Ollama configuration.
#
# When running with docker compose, the app container reaches Ollama via the
# service name:
#   OLLAMA_BASE_URL=http://ollama:11434
#
# When running uvicorn on the host with Ollama also on the host:
#   OLLAMA_BASE_URL=http://localhost:11434
#
# When running the app in Docker but Ollama on the host (Docker Desktop):
#   OLLAMA_BASE_URL=http://host.docker.internal:11434

OLLAMA_BASE_URL=http://localhost:11434

# Any Ollama-served model. Examples:
#   llama3.2:3b       - fast, small, good default for CPU
#   llama3.1:8b       - higher quality, needs ~8-10 GB RAM
#   qwen2.5:7b        - strong instruction follower
#   mistral:7b        - classic Mistral
#   phi3:mini         - very small, very fast
OLLAMA_MODEL=llama3.2:3b

# Optional tuning. The values below are the recommended defaults for
# local CPU-only runs against the US Constitution PDF; they match what
# the Docker image bakes in.
OLLAMA_TIMEOUT_S=300
RETRIEVAL_K=8

# Chunking strategy: "fixed" | "logical" | "semantic" (default: logical)
# CHUNKING_STRATEGY=logical
# CHUNK_SIZE_TARGET=900
# CHUNK_SIZE_MAX=1400
# CHUNK_OVERLAP_SENTENCES=1
# OLLAMA_NUM_PREDICT=512
# OLLAMA_KEEP_ALIVE=30m
